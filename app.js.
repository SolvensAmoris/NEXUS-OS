// NEXUS OS - CAPA 2 & 5: CONTEXT ENGINE & COPILOT UI
document.addEventListener('DOMContentLoaded', () => {
    const data = StorageManager.init();
    const chatContainer = document.getElementById('chat-container');
    const form = document.getElementById('nexus-form');
    const input = document.getElementById('user-input');
    const cashFlowDisplay = document.getElementById('cash-flow');

    if (cashFlowDisplay) cashFlowDisplay.textContent = `$${data.caja.toLocaleString('es-MX')} MXN`;

    function agregarMensaje(texto, esUsuario = false) {
        if (!chatContainer) return;
        const div = document.createElement('div');
        div.className = `flex gap-3 ${esUsuario ? 'flex-row-reverse' : ''} mb-4`;
        div.innerHTML = `
            <div class="w-8 h-8 rounded border border-emerald-500 bg-slate-800 flex items-center justify-center text-emerald-400 font-bold shrink-0">
                ${esUsuario ? 'Tú' : 'N'}
            </div>
            <div class="${esUsuario ? 'bg-slate-800 p-3 rounded-2xl rounded-tr-none text-sm' : 'glass-panel p-3 rounded-2xl rounded-tl-none text-sm'}">
                ${texto}
            </div>`;
        chatContainer.appendChild(div);
        chatContainer.scrollTop = chatContainer.scrollHeight;
    }

    form.addEventListener('submit', (e) => {
        e.preventDefault();
        const texto = input.value.trim();
        if (!texto) return;
        
        agregarMensaje(texto, true);
        input.value = '';
        
        // Lógica de respuesta simple
        const monto = texto.match(/\d+/);
        if (monto) {
            const nuevoSaldo = StorageManager.registrarMovimiento(texto.includes('gasto') ? 'egreso' : 'ingreso', parseInt(monto[0]));
            if (cashFlowDisplay) cashFlowDisplay.textContent = `$${nuevoSaldo.toLocaleString('es-MX')} MXN`;
            agregarMensaje(`Movimiento registrado. Saldo actualizado.`);
        } else {
            agregarMensaje("No detecté un monto. ¿Fue ingreso o gasto?");
        }
    });
});
